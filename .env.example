# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://earlyestate:earlyestate@localhost:5432/earlyestate
DATABASE_URL_SYNC=postgresql://earlyestate:earlyestate@localhost:5432/earlyestate

# ── Geocoding ─────────────────────────────────────────────────────────────────
# "nominatim" (free, self-hosted preferred) or "google"
GEOCODING_PROVIDER=nominatim
NOMINATIM_USER_AGENT=EarlyEstate/0.1
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ── North Data (company enrichment) ───────────────────────────────────────────
# NORTH_DATA_API_KEY=your_north_data_api_key

# ── Sprengnetter AVM (optional valuation) ─────────────────────────────────────
# SPRENGNETTER_API_KEY=your_sprengnetter_api_key

# ── Telegram alerts ───────────────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID=your_chat_id

# ── Email alerts (SMTP) ───────────────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your_app_password
# ALERT_FROM_EMAIL=alerts@earlyestate.local

# ── Webhook alerts ────────────────────────────────────────────────────────────
# WEBHOOK_URL=https://your-endpoint.example.com/webhook
# WEBHOOK_SECRET=your_hmac_signing_secret

# ── onOffice CRM (optional) ───────────────────────────────────────────────────
# ONOFFICE_API_KEY=your_onoffice_api_key
# ONOFFICE_API_SECRET=your_onoffice_api_secret

# ── Scheduler cadence ─────────────────────────────────────────────────────────
INSOLVENCY_POLL_MINUTES=30
BANK_PORTAL_POLL_HOURS=24

# ── Feature flags ─────────────────────────────────────────────────────────────
# ZVG portal disabled by default — robots.txt disallows detail endpoints.
# Enable only after legal/compliance review.
ZVG_ADAPTER_ENABLED=false
